      "targets": [
        {
          "expr": "probe_success{job=\"petwell-readiness\"}",
          "legendFormat": "{{service}}"
        }
      ],
      "title": "Service Readiness",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },

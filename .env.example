PROJECT_NAME=petwell
NODE_ENV=development

GATEWAY_PORT=3000
PUBLIC_WEB_PORT=3001
ADMIN_WEB_PORT=3002

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=petwell-assets

MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_FROM=hello@petwell.local

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
FIELD_ENCRYPTION_KEY=change-me-32-byte-field-key-123456
EHR_STORAGE_PATH=/var/lib/petwell-ehr

# Local default stays mock. Preferred real provider: wompi.
PAYMENT_PROVIDER=mock
PAYMENT_CURRENCY=COP
PAYMENT_COLLECTOR=petwell
PAYMENT_PLATFORM_FEE=0

WOMPI_SANDBOX_PUBLIC_KEY=
WOMPI_SANDBOX_PRIVATE_KEY=
WOMPI_SANDBOX_INTEGRITY_SECRET=
WOMPI_SANDBOX_EVENTS_SECRET=
WOMPI_PRODUCTION_PUBLIC_KEY=
WOMPI_PRODUCTION_PRIVATE_KEY=
WOMPI_PRODUCTION_INTEGRITY_SECRET=
WOMPI_PRODUCTION_EVENTS_SECRET=

MERCADOPAGO_SANDBOX_ACCESS_TOKEN=
MERCADOPAGO_SANDBOX_WEBHOOK_SECRET=
MERCADOPAGO_PRODUCTION_ACCESS_TOKEN=
MERCADOPAGO_PRODUCTION_WEBHOOK_SECRET=

# Local default stays mock. Preferred real provider: daily.
TELEMED_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
DAILY_API_KEY=

PUBLIC_APP_URL=http://localhost
ADMIN_APP_URL=http://localhost/admin
API_PUBLIC_URL=http://localhost/api
NEXT_PUBLIC_API_URL=/api

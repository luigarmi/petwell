{
  "name": "petwell-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:web",
    "dev:gateway": "tsx watch apps/gateway/src/index.ts",
    "dev:user-service": "tsx watch apps/services/user-service/src/index.ts",
    "dev:pet-service": "tsx watch apps/services/pet-service/src/index.ts",
    "dev:ehr-service": "tsx watch apps/services/ehr-service/src/index.ts",
    "dev:appointment-service": "tsx watch apps/services/appointment-service/src/index.ts",
    "dev:billing-service": "tsx watch apps/services/billing-service/src/index.ts",
    "dev:telemed-service": "tsx watch apps/services/telemed-service/src/index.ts",
    "dev:notification-service": "tsx watch apps/services/notification-service/src/index.ts",
    "dev:analytics-service": "tsx watch apps/services/analytics-service/src/index.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "start:gateway": "tsx apps/gateway/src/index.ts",
    "start:user-service": "tsx apps/services/user-service/src/index.ts",
    "start:pet-service": "tsx apps/services/pet-service/src/index.ts",
    "start:ehr-service": "tsx apps/services/ehr-service/src/index.ts",
    "start:appointment-service": "tsx apps/services/appointment-service/src/index.ts",
    "start:billing-service": "tsx apps/services/billing-service/src/index.ts",
    "start:telemed-service": "tsx apps/services/telemed-service/src/index.ts",
    "start:notification-service": "tsx apps/services/notification-service/src/index.ts",
    "start:analytics-service": "tsx apps/services/analytics-service/src/index.ts",
    "start:web": "vite --config apps/web/vite.config.ts --host 0.0.0.0 --port 3000",
    "init:managed-db": "powershell -ExecutionPolicy Bypass -File .\\scripts\\init-managed-postgres.ps1",
    "typecheck": "tsc --noEmit",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "smoke": "powershell -ExecutionPolicy Bypass -File .\\scripts\\smoke-test.ps1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "uuid": "^11.1.0",
    "vite": "^7.1.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}

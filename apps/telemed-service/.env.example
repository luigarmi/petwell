SERVICE_NAME=telemed-service
NODE_ENV=development
PORT=3006
CORS_ORIGIN=http://localhost,http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@telemed-db:5432/petwell_telemed
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
REDIS_URL=redis://redis:6379
PUBLIC_APP_URL=http://localhost
TELEMED_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
DAILY_API_KEY=
LOG_FILE_PATH=/var/log/petwell/telemed-service.log

SERVICE_NAME=notification-service
NODE_ENV=development
PORT=3007
CORS_ORIGIN=http://localhost,http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@notification-db:5432/petwell_notification
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
REDIS_URL=redis://redis:6379
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_FROM=hello@petwell.local
USER_SERVICE_URL=http://user-service:3001
APPOINTMENT_SERVICE_URL=http://appointment-service:3004
LOG_FILE_PATH=/var/log/petwell/notification-service.log

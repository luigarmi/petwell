generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@petwell/prisma-analytics-service-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AnalyticsEvent {
  id         String   @id
  eventName  String
  clinicId   String?
  payload    Json?
  occurredAt DateTime
  createdAt  DateTime @default(now())

  @@index([eventName, occurredAt])
  @@index([clinicId, occurredAt])
}

SERVICE_NAME=analytics-service
NODE_ENV=development
PORT=3008
CORS_ORIGIN=http://localhost,http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@analytics-db:5432/petwell_analytics
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
REDIS_URL=redis://redis:6379
BILLING_SERVICE_URL=http://billing-service:3005
APPOINTMENT_SERVICE_URL=http://appointment-service:3004
PET_SERVICE_URL=http://pet-service:3002
LOG_FILE_PATH=/var/log/petwell/analytics-service.log

SERVICE_NAME=ehr-service
NODE_ENV=development
PORT=3003
CORS_ORIGIN=http://localhost,http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@ehr-db:5432/petwell_ehr
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
REDIS_URL=redis://redis:6379
FIELD_ENCRYPTION_KEY=change-me-32-byte-field-key-123456
LOG_FILE_PATH=/var/log/petwell/ehr-service.log
